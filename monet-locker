def log(msg):
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now().isoformat(timespec="seconds")
    with open(LOG_FILE, "a", encoding="utf-8") as f:
        f.write(f"{stamp} {msg}\n")


def acquire_instance_lock():
    LOCKFILE.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(LOCKFILE, os.O_CREAT | os.O_RDWR, 0o600)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        os.close(fd)
        log("refusing start: another monet-locker-v2 instance is active")
        raise SystemExit(4)
    os.ftruncate(fd, 0)
    os.write(fd, str(os.getpid()).encode("ascii"))
    return fd


def ensure_display_ready():
    try:
        subprocess.check_call(
            ["timeout", "3", "xdpyinfo"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        log("refusing start: X display is not ready")
        raise SystemExit(5)


# -- monitor detection ------------------------------------------------------
def _detect_monitors_once():
    try:
        out = subprocess.check_output(["xrandr", "--listmonitors"], text=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []

    mons = []
    for line in out.splitlines()[1:]:
        m = re.match(r"\s*\d+:\s*(\+?\*?)(\S+)\s+(\d+)/\d+x(\d+)/\d+([+-]\d+)([+-]\d+)", line)
        if not m:
            continue
        flags, name, w, h, x, y = m.groups()
        mons.append({
            "name": name,
            "x": int(x), "y": int(y),
            "w": int(w), "h": int(h),
            "primary": "*" in flags,
        })
    return mons


def _monitor_signature(monitors):
    return tuple((m["name"], m["x"], m["y"], m["w"], m["h"], m["primary"]) for m in monitors)


def detect_monitors():
    previous = None
    for _ in range(3):
        mons = _detect_monitors_once()
        if mons and previous == _monitor_signature(mons):
            break
        previous = _monitor_signature(mons)
        time.sleep(0.25)
    else:
        mons = _detect_monitors_once()

    if not mons:
        log("refusing start: no monitors reported by xrandr")
        raise SystemExit(6)
    if not any(m["primary"] for m in mons):
        mons[0]["primary"] = True
    total_area = sum(m["w"] * m["h"] for m in mons)
    if total_area < 800 * 600:
        log(f"refusing start: invalid monitor area {total_area}")
        raise SystemExit(7)
    log("monitors " + ",".join(f"{m['name']}={m['w']}x{m['h']}+{m['x']}+{m['y']}" for m in mons))
    return mons


